# Server Configuration
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://b2g-vault.com

# Email Service (Choose one)
# Option 1: Resend (3000 emails/month free) - RECOMMENDED
RESEND_API_KEY=re_your_api_key_here
# Option 2: Brevo (300 emails/day free)
BREVO_API_KEY=your_brevo_api_key_here

# Email Settings
EMAIL_FROM=noreply@b2g-vault.com
EMAIL_SERVICE=resend

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
MAGIC_LINK_EXPIRY=900000

# CORS
ALLOWED_ORIGINS=https://b2g-vault.com,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# Message Expiry (24 hours in milliseconds)
MAX_MESSAGE_TTL=86400000
